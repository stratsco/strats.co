# strats.co — environment template (no secrets committed)
#
# Local usage:
#   cp .env.example .env          # Astro/Vite/scripts that read dotenv
#   cp .dev.vars.example .dev.vars   # Wrangler local dev (Pages/Worker)
#
# Production / preview on Cloudflare: set secrets with Wrangler or the dashboard
#   wrangler secret put DISCORD_PUBLIC_KEY
#   wrangler secret list
#
# Cursor: use the Cloudflare MCP (Bindings) tools to list accounts, create D1/KV/R2,
# and search docs; use `wrangler whoami` / `wrangler login` in the terminal.

# -----------------------------------------------------------------------------
# Cloudflare (optional — often `wrangler login` is enough locally)
# -----------------------------------------------------------------------------
# Account ID from dashboard URL or `wrangler whoami`
# CLOUDFLARE_ACCOUNT_ID=

# API token for CI or scripts (least privilege: edit Cloudflare Workers, D1, etc.)
# CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Site (Astro: only PUBLIC_* is exposed to the browser)
# -----------------------------------------------------------------------------
# PUBLIC_SITE_URL=http://localhost:4321

# -----------------------------------------------------------------------------
# Discord (treat all of these as secrets in deployed environments)
# -----------------------------------------------------------------------------
# Application ID (Developer Portal → Your app → General)
DISCORD_APPLICATION_ID=

# Public key — verify incoming interaction signatures (Interactions endpoint)
DISCORD_PUBLIC_KEY=

# Bot token — Gateway/worker-style bots only; do not bundle in client code
DISCORD_BOT_TOKEN=

# OAuth2 client secret — only if the site implements Discord OAuth (optional)
# DISCORD_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Internal calls (e.g. apps/discord-gateway → your API on Cloudflare)
# -----------------------------------------------------------------------------
# Shared secret for Authorization header / internal routes
# STRATS_INTERNAL_API_SECRET=
