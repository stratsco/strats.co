{
  "name": "strats-co",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "concurrently -n web,discord,seed \"pnpm --filter @strats/web dev\" \"pnpm --filter @strats/discord dev\"",
    "build": "pnpm -r --filter \"@strats/*\" build",
    "lint": "pnpm -r --filter \"@strats/*\" lint",
    "typecheck": "pnpm -r --filter \"@strats/*\" typecheck",
    "test": "pnpm -r --filter \"@strats/*\" test",
    "deploy:dry-run": "pnpm -r --filter @strats/web --filter @strats/discord deploy:dry-run",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
